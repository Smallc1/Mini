# SQLite file path is relative to prisma/schema.prisma.
DATABASE_URL="file:../data/production.db"
AUTH_SECRET="replace-with-at-least-32-random-bytes"
AUTH_TRUST_HOST=true
NEXT_PUBLIC_APP_URL="https://shop.example.com"

# Optional: required only for password-reset email.
QQ_SMTP_USER=""
QQ_SMTP_AUTH_CODE=""
